{
  "name": "shuxia/toolbox-backend",
  "description": "Hyperf backend for Shuxia Toolbox.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.4",
    "guzzlehttp/guzzle": "^7.9",
    "hyperf/config": "^3.2@beta",
    "hyperf/di": "^3.2@beta",
    "hyperf/engine": "^2.11",
    "hyperf/framework": "^3.2@beta",
    "hyperf/http-server": "^3.2@beta",
    "hyperf/logger": "^3.2@beta",
    "hyperf/server": "^3.2@beta",
    "hyperf/support": "^3.2@beta"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.64"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "start": "php bin/hyperf.php start",
    "cs:fix": "php-cs-fixer fix"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://repo.packagist.org",
      "canonical": true
    }
  ],
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "beta",
  "prefer-stable": true
}
