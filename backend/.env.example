APP_NAME=shuxia-toolbox-api
APP_ENV=dev
SERVER_PORT=9501
WECHAT_MINI_APPID=
WECHAT_MINI_SECRET=

# 旅游攻略图：地图服务（腾讯位置服务 WebServiceAPI key，申请 https://lbs.qq.com/）
TENCENT_MAP_KEY=
# SK 签名（SN 校验）：控制台 key 开启「SN校验」后生成的 SecretKey，用于给所有腾讯 API 请求计算 sig。
# 开启 SN 校验后，旧的 IP 白名单失效，无 sig 的请求会被拒（返回签名错误）。
TENCENT_MAP_SK=
MAP_PROVIDER=tencent
MAP_TIMEOUT=5

# 旅游攻略图：AI 行程规划（智谱 GLM，申请 https://open.bigmodel.cn/）
AI_PROVIDER=zhipu
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-5.2
# 关闭思考模式（glm-5.2 支持，关掉更快更省）
ZHIPU_THINKING=disabled
# 联网搜索（true=AI 自行上网查目的地最新信息再综合，质量高但慢/贵）
ZHIPU_WEB_SEARCH=true
AI_TIMEOUT=120

# 接口鉴权：前端随请求头 X-API-Key 带上，后端中间件校验。填 openssl rand -hex 32 生成的强随机串。
APP_API_KEY=

# Redis（限流计数用；开发环境 redis 为同 docker 网络的服务名）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
